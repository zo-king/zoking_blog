APP_ENV=development
QA_E2E_CLEANUP_ENABLED=false
APP_NAME=zoking-blog
APP_PORT=18080

DATABASE_URL=postgres://zoking:zoking_dev_password@localhost:15432/zoking_blog?sslmode=disable
DB_MAX_OPEN_CONNS=20
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=1h

JWT_SECRET=dev-only-change-me-with-long-random-string
ACCESS_TOKEN_TTL=30m
REFRESH_TOKEN_TTL=720h

SEED_ADMIN_EMAIL=admin@zoking.local
SEED_ADMIN_PASSWORD=ChangeMe123!

CORS_ALLOWED_ORIGINS=http://localhost:1313
ADMIN_ALLOWED_ORIGINS=http://localhost:5173
MEDIA_UPLOAD_MAX_CONCURRENCY=4
TRUSTED_PROXIES=127.0.0.1,::1
COMMENT_RATE_LIMIT_PER_MINUTE=10
COMMENT_RATE_LIMIT_BURST=5
REQUEST_MAX_BYTES=16777216
# Public URL inputs. Production values are set in infra/docker/.env.prod.
SITE_BASE_URL=http://localhost:1313/
PUBLIC_API_BASE_URL=http://localhost:18080
VITE_API_BASE_URL=http://localhost:18080

MEDIA_STORAGE_DRIVER=local
MEDIA_LOCAL_DIR=./storage/media
MEDIA_PUBLIC_BASE_URL=/media-files
MEDIA_MAX_BYTES=10485760
MEDIA_ORPHAN_GRACE_PERIOD=168h
MEDIA_CLEANUP_BATCH_SIZE=100

HUGO_SITE_DIR=../../apps/site
HUGO_PUBLIC_DIR=./dist/site
HUGO_BIN=./.tools/hugo/hugo.exe
MIGRATIONS_DIR=../../db/migrations

PUBLISH_WORKER_ENABLED=true
PUBLISH_WORKER_POLL_INTERVAL=2s
PUBLISH_JOB_TIMEOUT=2m
PUBLISH_MAX_RETRIES=3
PUBLISH_RELEASE_KEEP_LATEST=20
PUBLISH_RELEASE_KEEP_DAYS=30
PUBLISH_RELEASE_ROOT=./dist/releases
PUBLISH_CURRENT_DIR=./dist/site
PUBLISH_PREVIEW_ROOT=./dist/previews
PUBLISH_PREVIEW_PUBLIC_BASE_URL=/preview-files
PUBLISH_PREVIEW_TTL=24h
PUBLISH_PREVIEW_CLEANUP_INTERVAL=1h
PUBLISH_PREVIEW_CLEANUP_BATCH_SIZE=100
# Keep the local Hugo comments endpoint equal to PUBLIC_API_BASE_URL.
# Production Compose derives this value from PUBLIC_API_BASE_URL.
HUGO_COMMENTS_API_BASE=http://localhost:18080
