TZ=Asia/Shanghai

POSTGRES_DB=zoking_blog
POSTGRES_USER=zoking
POSTGRES_PASSWORD=__REQUIRED_RANDOM_POSTGRES_PASSWORD__

JWT_SECRET=__REQUIRED_RANDOM_JWT_SECRET_AT_LEAST_32_CHARS__
SEED_ADMIN_EMAIL=owner@zoking.tech
SEED_ADMIN_PASSWORD=__REQUIRED_RANDOM_ADMIN_PASSWORD_AT_LEAST_16_CHARS__

API_PORT=18080
ADMIN_PORT=8081
SITE_PORT=1313
API_BIND_ADDRESS=127.0.0.1
ADMIN_BIND_ADDRESS=127.0.0.1
SITE_BIND_ADDRESS=127.0.0.1
# API, worker, and Admin receive these public URLs; derived consumers below
# must continue to use them as their single source of truth.
SITE_BASE_URL=https://zoking.tech/
PUBLIC_API_BASE_URL=https://api.zoking.tech
PUBLISH_PREVIEW_PUBLIC_BASE_URL=https://preview.zoking.tech/preview-files
CORS_ALLOWED_ORIGINS=https://zoking.tech
ADMIN_ALLOWED_ORIGINS=https://admin.zoking.tech
TRUSTED_PROXIES=127.0.0.1,::1
COMMENT_RATE_LIMIT_PER_MINUTE=10
COMMENT_RATE_LIMIT_BURST=5
MEDIA_UPLOAD_MAX_CONCURRENCY=4

PUBLISH_WORKER_POLL_INTERVAL=2s
PUBLISH_JOB_TIMEOUT=2m
PUBLISH_MAX_RETRIES=3
PUBLISH_RELEASE_KEEP_LATEST=20
PUBLISH_RELEASE_KEEP_DAYS=30
PUBLISH_RELEASE_ROOT=/data/releases
PUBLISH_CURRENT_DIR=/data/current
PUBLISH_PREVIEW_ROOT=/data/previews
PUBLISH_PREVIEW_TTL=24h
PUBLISH_PREVIEW_CLEANUP_INTERVAL=1h
PUBLISH_PREVIEW_CLEANUP_BATCH_SIZE=100
MEDIA_ORPHAN_GRACE_PERIOD=168h
MEDIA_CLEANUP_BATCH_SIZE=100
